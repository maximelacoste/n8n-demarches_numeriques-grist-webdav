      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Préparer le dossier"
    },
    {
      "parameters": {
        "method": "MKCOL",
        "url": "=https://WEBDAV_HOST/remote.php/dav/files/WEBDAV_USER/WEBDAV_BASE_PATH/{{ encodeURIComponent($json.nomDossier) }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1392, 0],
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "MKCOL dossier",
      "continueOnFail": true,
      "credentials": {
        "httpBasicAuth": {
          "id": "CREDENTIAL_ID_WEBDAV",
          "name": "Votre credential WebDAV"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ─── Helpers ─────────────────────────────────────────────────────────────────\n// Extrait récursivement toutes les PièceJustificativeChamp (y compris dans les RepetitionChamp)\nfunction extractFiles(fields) {\n  const files = [];\n  for (const field of fields) {\n    if (!field || !field.__typename) continue;\n    if (field.__typename === 'PieceJustificativeChamp' && field.files?.length > 0) {\n      for (const f of field.files) files.push({ ...f, label: field.label });\n    }\n    if (field.__typename === 'RepetitionChamp' && field.rows) {\n      for (const row of field.rows) {\n        if (row.champs) files.push(...extractFiles(row.champs));\n      }\n    }\n  }\n  return files;\n}\n\n// Dédoublonne par URL (même fichier sur plusieurs champs)\nfunction deduplicateByUrl(files) {\n  const seen = new Set();\n  return files.filter(f => {\n    if (seen.has(f.url)) return false;\n    seen.add(f.url);\n    return true;\n  });\n}\n\n// ─── Lecture des données préparées ────────────────────────────────────────────\n// $json = réponse du MKCOL → on remonte sur le Set node\nconst prepared  = $('Préparer le dossier').item.json;\nconst dossier   = prepared.dossierData;\nconst numero    = prepared.numero;\nconst nom       = prepared.nom;\nconst prenom    = prepared.prenom;\nconst nomDossier = prepared.nomDossier;\nconst recordId  = prepared.recordId;\n\nif (!dossier) return [];\n\nconst allFiles = deduplicateByUrl([\n  ...extractFiles(dossier.annotations || []),\n  ...extractFiles(dossier.champs || [])\n]);\n\nconst totalFiles = allFiles.length;\nif (totalFiles === 0) return [];\n\nconst results = [];\n\nfor (let i = 0; i < allFiles.length; i++) {\n  const file      = allFiles[i];\n  const fileIndex = i + 1;\n\n  // Nommage : numéro_dossier + index (si plusieurs fichiers) + nom original sanitisé\n  const safeName = file.filename.replace(/[^a-zA-Z0-9._-]/g, '_');\n  const filename = totalFiles === 1\n    ? `${numero}_${safeName}`\n    : `${numero}_${String(fileIndex).padStart(2, '0')}_${safeName}`;\n\n  const buf = await this.helpers.request({\n    method: 'GET',\n    url: file.url,\n    encoding: null\n  });\n\n  const binaryData = await this.helpers.prepareBinaryData(\n    buf,\n    filename,\n    file.contentType || 'application/pdf'\n  );\n\n  results.push({\n    json: {\n      recordId,\n      numero,\n      nom,\n      prenom,\n      filename,\n      nomDossier,\n      fileIndex,\n      totalFiles,\n      isLastFile: fileIndex === totalFiles\n    },\n    binary: { file1: binaryData }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
