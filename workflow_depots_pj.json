              "value": "={{ ($json.data.dossier.demandeur?.prenom || 'inconnu').trim() }}",
              "type": "string"
            },
            {
              "id": "set-nomdossier",
              "name": "nomDossier",
              "value": "={{ ($json.data.dossier.number + '_' + ($json.data.dossier.demandeur?.nom || 'INCONNU').trim().toUpperCase() + '_' + ($json.data.dossier.demandeur?.prenom || 'inconnu').trim()).replace(/[\\s''']/g, '_') }}",
              "type": "string"
            },
