    {
      "parameters": {
        "method": "POST",
        "url": "https://demarche.numerique.gouv.fr/api/v2/graphql",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": \"{ dossier(number: {{ $json.GRIST_FIELD_DN_NUMBER }}) { number demandeur { ... on PersonnePhysique { nom prenom } } annotations { __typename ... on PieceJustificativeChamp { label files { filename url contentType } } ... on RepetitionChamp { label rows { champs { __typename ... on PieceJustificativeChamp { label files { filename url contentType } } } } } } champs { __typename ... on PieceJustificativeChamp { label files { filename url contentType } } ... on RepetitionChamp { label rows { champs { __typename ... on PieceJustificativeChamp { label files { filename url contentType } } } } } } } }\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [912, 0],
      "id": "d4c390cc-6ec4-466a-b986-ee8e9feeaa44",
      "name": "DS: Récupérer les PJ du dossier",
      "credentials": {
        "httpBearerAuth": {
          "id": "CREDENTIAL_ID_DS_TOKEN",
          "name": "Votre token API Démarches Numériques"
        }
      }
    },
    {
